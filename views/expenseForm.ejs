<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Add Expense</title>

  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gradient-to-br from-blue-900 via-indigo-900 to-slate-950 min-h-screen flex items-center justify-center text-white p-4">

  <!-- CARD -->
  <div class="w-full max-w-md sm:max-w-lg bg-white/10 p-5 sm:p-6 lg:p-8 rounded-3xl border border-blue-400/20 shadow-2xl">

    <!-- HEADER -->
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mb-6">

      <!-- Back Button -->
      <a href="/expense"
         class="self-start sm:self-auto px-3 py-2 text-sm rounded-lg 
         bg-white/10 border border-blue-400/20 
         hover:bg-white/20 transition">
        ← Back
      </a>

      <!-- Title -->
      <h2 class="text-2xl sm:text-3xl text-center sm:text-left font-bold text-cyan-300">
        Add Expense
      </h2>

      <!-- Spacer -->
      <div class="hidden sm:block w-[60px]"></div>

    </div>

    <!-- FORM -->
    <form action="/expense" method="POST" class="space-y-4 sm:space-y-5">

      <!-- Amount -->
      <input type="number" name="amount" placeholder="Amount" required
        class="w-full p-3 rounded-xl bg-white/10 border border-blue-400/20 outline-none focus:ring-2 focus:ring-cyan-400"/>

      <!-- Category -->
      <input type="text" name="category" placeholder="Category (salary, bills)" required
        class="w-full p-3 rounded-xl bg-white/10 border border-blue-400/20 outline-none focus:ring-2 focus:ring-cyan-400"/>

      <!-- Description -->
      <input type="text" name="description" placeholder="Description"
        class="w-full p-3 rounded-xl bg-white/10 border border-blue-400/20 outline-none focus:ring-2 focus:ring-cyan-400"/>

      <!-- BUTTON -->
      <button class="w-full py-3 bg-red-400 rounded-xl hover:scale-105 transition font-semibold shadow-lg">
        Save Expense
      </button>

    </form>

  </div>

</body>
</html>