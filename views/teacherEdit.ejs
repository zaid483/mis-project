<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Edit Teacher</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gradient-to-br from-blue-900 via-indigo-900 to-slate-950 min-h-screen flex items-center justify-center p-4 text-white">

  <!-- Glass Card -->
  <div class="w-full max-w-lg backdrop-blur-xl bg-white/5 border border-white/10 rounded-3xl shadow-2xl p-8">

    <!-- Header -->
    <div class="flex justify-between items-center mb-8">
      <h2 class="text-3xl font-bold text-cyan-300">Edit Teacher</h2>

      <a href="/teachers"
         class="text-sm px-4 py-2 bg-white/10 border border-white/20 rounded-xl hover:bg-white/20 transition">
        ← Back
      </a>
    </div>

    <!-- Form -->
    <form action="/teachers/update/<%= teacher._id %>" method="POST" class="space-y-6">

      <!-- Name -->
      <div>
        <label class="block text-sm text-gray-300 mb-1">Full Name</label>
        <input 
          type="text" 
          name="name" 
          value="<%= teacher.name %>" 
          class="w-full p-3 rounded-xl bg-white/10 border border-white/20 focus:outline-none focus:ring-2 focus:ring-cyan-400"
          required
        />
      </div>

      <!-- Subject -->
      <div>
        <label class="block text-sm text-gray-300 mb-1">Subject</label>
        <input 
          type="text" 
          name="subject" 
          value="<%= teacher.subject %>" 
          class="w-full p-3 rounded-xl bg-white/10 border border-white/20 focus:outline-none focus:ring-2 focus:ring-cyan-400"
          required
        />
      </div>

      <!-- Salary -->
      <div>
        <label class="block text-sm text-gray-300 mb-1">Salary</label>
        <input 
          type="number" 
          name="salary" 
          value="<%= teacher.salary %>" 
          class="w-full p-3 rounded-xl bg-white/10 border border-white/20 focus:outline-none focus:ring-2 focus:ring-cyan-400"
          required
        />
      </div>

      <!-- Phone -->
      <div>
        <label class="block text-sm text-gray-300 mb-1">Phone</label>
        <input 
          type="text" 
          name="phone" 
          value="<%= teacher.phone %>" 
          class="w-full p-3 rounded-xl bg-white/10 border border-white/20 focus:outline-none focus:ring-2 focus:ring-cyan-400"
        />
      </div>

      <!-- Buttons -->
      <div class="flex justify-between items-center pt-4">

        <a href="/teachers"
           class="px-5 py-2 rounded-xl bg-red-400/80 hover:bg-red-400 text-black font-medium transition">
          Cancel
        </a>

        <button 
          class="px-6 py-2 rounded-xl bg-gradient-to-r from-cyan-400 to-blue-500 text-black font-semibold hover:scale-105 transition">
          Update Teacher
        </button>

      </div>

    </form>

  </div>

</body>
</html>