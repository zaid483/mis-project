<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Expense List</title>

  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gradient-to-br from-slate-950 via-slate-900 to-indigo-950 text-white min-h-screen">

<div class="flex flex-col lg:flex-row min-h-screen">

  <!-- SIDEBAR -->
  <div class="w-full lg:w-80 flex-shrink-0">
    <%- include('partials/sidebar') %>
  </div>

  <!-- MAIN -->
  <div class="flex-1 flex justify-center px-3 sm:px-6 lg:px-10 py-5">

    <!-- 🔥 ULTRA RESPONSIVE CONTAINER -->
    <div class="w-full max-w-6xl xl:max-w-7xl 2xl:max-w-[1600px]">

      <!-- HEADER -->
      <div class="flex flex-col sm:flex-row sm:justify-between sm:items-center gap-4 mb-6">

        <h2 class="text-2xl sm:text-3xl font-bold text-indigo-200">
          Expense List
        </h2>

        <a href="/expense/add"
   class="flex items-center gap-4 px-6 py-4 rounded-xl
          bg-white/5 backdrop-blur-xl
          border border-white/10
          text-slate-200
          transition-all duration-300

          hover:bg-white/10
          hover:border-rose-400/30
          hover:shadow-md hover:shadow-rose-500/10
          hover:scale-[1.03]">

  <!-- ICON -->
  <div class="w-11 h-11 flex items-center justify-center rounded-lg
              bg-rose-500/10 border border-rose-400/20">
    <i class="fa-solid fa-receipt text-rose-300 text-lg"></i>
  </div>

  <!-- TEXT -->
  <div class="flex flex-col">
    <span class="text-base font-medium">Add Expense</span>
    <span class="text-xs text-slate-400">Create new expense record</span>
  </div>

</a>

      </div>

      <!-- TOTAL -->
      <div class="mb-6 text-lg sm:text-xl text-slate-300">
        Total Expense:
        <span class="font-bold text-rose-400">$<%= totalExpense %></span>
      </div>

      <!-- ================= DESKTOP TABLE ================= -->
      <div class="hidden md:block rounded-2xl border border-white/10 bg-slate-900/40 backdrop-blur-xl overflow-hidden">

        <table class="w-full text-left">

          <thead class="bg-slate-800/60 text-indigo-200">
            <tr class="text-sm 2xl:text-base">
              <th class="p-4 2xl:p-6">#</th>
              <th class="p-4 2xl:p-6">Amount</th>
              <th class="p-4 2xl:p-6">Category</th>
              <th class="p-4 2xl:p-6">Description</th>
              <th class="p-4 2xl:p-6">Date</th>
            </tr>
          </thead>

          <tbody class="text-sm 2xl:text-base">

            <% expenses.forEach((exp, i) => { %>
              <tr class="border-t border-white/5 hover:bg-white/5 transition">

                <td class="p-4 2xl:p-6"><%= i + 1 %></td>

                <td class="p-4 2xl:p-6 text-rose-400 font-bold">
                  $<%= exp.amount %>
                </td>

                <td class="p-4 2xl:p-6 text-slate-300">
                  <%= exp.category %>
                </td>

                <td class="p-4 2xl:p-6 text-slate-400">
                  <%= exp.description || "N/A" %>
                </td>

                <td class="p-4 2xl:p-6 text-slate-500">
                  <%= new Date(exp.date).toDateString() %>
                </td>

              </tr>
            <% }) %>

          </tbody>

        </table>

      </div>

      <!-- ================= MOBILE CARDS ================= -->
      <div class="md:hidden space-y-4">

        <% expenses.forEach((exp, i) => { %>

          <div class="bg-slate-900/40 border border-white/10 rounded-xl p-4 backdrop-blur-xl">

            <div class="flex justify-between items-center mb-2">
              <h3 class="font-bold text-rose-400">
                $<%= exp.amount %>
              </h3>
              <span class="text-sm text-slate-400">#<%= i + 1 %></span>
            </div>

            <p class="text-sm text-slate-300">
              Category: <%= exp.category %>
            </p>

            <p class="text-sm text-slate-400">
              Description: <%= exp.description || "N/A" %>
            </p>

            <p class="text-xs text-slate-500 mt-1">
              Date: <%= new Date(exp.date).toDateString() %>
            </p>

          </div>

        <% }) %>

      </div>

    </div>
  </div>

</div>

</body>
</html>