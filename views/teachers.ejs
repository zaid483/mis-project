<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Teachers</title>

  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
</head>

<body class="bg-gradient-to-br from-slate-950 via-slate-900 to-indigo-950 text-white min-h-screen">

<div class="flex flex-col lg:flex-row min-h-screen">

  <!-- SIDEBAR -->
  <div class="w-full lg:w-80">
    <%- include('partials/sidebar') %>
  </div>

  <!-- MAIN -->
  <main class="flex-1 p-4 sm:p-6 lg:p-10">

    <!-- 🔥 ULTRA WIDE CONTAINER (FIX 4K GAP) -->
    <div class="w-full max-w-6xl xl:max-w-7xl 2xl:max-w-[1600px] 3xl:max-w-[2000px] mx-auto">

      <!-- HEADER -->
      <div class="flex flex-col sm:flex-row sm:justify-between sm:items-center gap-6 mb-10">

        <h2 class="text-3xl sm:text-4xl 2xl:text-5xl font-bold text-indigo-200">
          Teachers List
        </h2>
<a href="/teachers/add"
   class="flex items-center gap-4 px-6 py-4 rounded-xl
          bg-white/5 backdrop-blur-xl
          border border-white/10
          text-slate-200
          transition-all duration-300

          hover:bg-white/10
          hover:border-indigo-400/30
          hover:shadow-md hover:shadow-indigo-500/10
          hover:scale-[1.03]">

  <!-- ICON -->
  <div class="w-11 h-11 flex items-center justify-center rounded-lg
              bg-indigo-500/10 border border-indigo-400/20">
    <i class="fa-solid fa-user-tie text-indigo-300 text-lg"></i>
  </div>

  <!-- TEXT -->
  <div class="flex flex-col">
    <span class="text-base font-medium">Add Teacher</span>
    <span class="text-xs text-slate-400">Create new record</span>
  </div>

</a>
      </div>

      <!-- ================= DESKTOP TABLE ================= -->
      <div class="hidden md:block rounded-2xl border border-white/10 
                  bg-slate-900/40 backdrop-blur-xl overflow-hidden">

        <table class="w-full text-left">

          <thead class="bg-slate-800/60 text-indigo-200">
            <tr class="text-base 2xl:text-lg">
              <th class="p-6">#</th>
              <th class="p-6">Name</th>
              <th class="p-6">Subject</th>
              <th class="p-6">Salary</th>
              <th class="p-6">Phone</th>
              <th class="p-6">Created</th>
              <th class="p-6">Actions</th>
            </tr>
          </thead>

          <tbody class="text-base 2xl:text-lg">

            <% teachers.forEach((teacher, index) => { %>
              <tr class="border-t border-white/5 
                         hover:bg-white/5 transition duration-300">

                <td class="p-6"><%= index + 1 %></td>

                <td class="p-6 font-semibold"><%= teacher.name %></td>

                <td class="p-6 text-slate-300"><%= teacher.subject %></td>

                <td class="p-6 text-emerald-400 font-medium">
                  $<%= teacher.salary %>
                </td>

                <td class="p-6 text-slate-300">
                  <%= teacher.phone || "N/A" %>
                </td>

                <td class="p-6 text-slate-400 text-sm 2xl:text-base">
                  <%= new Date(teacher.createdAt).toLocaleDateString() %>
                </td>

                <td class="p-6 flex gap-5">

                   <a href="/teachers/edit/<%= teacher._id %>" class="text-cyan-300">
                    <i class="fa-solid fa-pen-to-square"></i>
                  </a>

                  <a href="/teachers/delete/<%= teacher._id %>"
                     onclick="return confirm('Are you sure?')"
                     class="text-rose-400 hover:scale-110 transition">
                    <i class="fa-solid fa-trash text-xl"></i>
                  </a>

                </td>

              </tr>
            <% }) %>

          </tbody>

        </table>
      </div>

      <!-- ================= MOBILE CARDS ================= -->
      <div class="md:hidden space-y-6">

        <% teachers.forEach((teacher, index) => { %>

          <div class="bg-slate-900/40 border border-white/10 
                      rounded-2xl p-6 backdrop-blur-xl
                      hover:scale-[1.02] transition">

            <div class="flex justify-between items-center mb-3">
              <h3 class="font-bold text-indigo-200 text-xl">
                <%= teacher.name %>
              </h3>
              <span class="text-sm text-slate-400">#<%= index + 1 %></span>
            </div>

            <p class="text-base text-slate-300">Subject: <%= teacher.subject %></p>
            <p class="text-base text-emerald-400">Salary: $<%= teacher.salary %></p>
            <p class="text-base text-slate-300">Phone: <%= teacher.phone || "N/A" %></p>

            <p class="text-sm text-slate-400 mt-2">
              Created: <%= new Date(teacher.createdAt).toLocaleDateString() %>
            </p>

            <div class="flex gap-6 mt-5">

              <button class="text-indigo-300 hover:scale-110 transition">
                <i class="fa-solid fa-pen-to-square text-xl"></i>
              </button>

              <a href="/teachers/delete/<%= teacher._id %>"
                 onclick="return confirm('Are you sure?')"
                 class="text-rose-400 hover:scale-110 transition">
                <i class="fa-solid fa-trash text-xl"></i>
              </a>

            </div>

          </div>

        <% }) %>

      </div>

    </div>
  </main>

</div>

</body>
</html>